# Open Lovable Configuration - Coolify Provider

# Sandbox Provider
SANDBOX_PROVIDER=coolify

# REQUIRED - Coolify Instance and Token
# Your Coolify API Token (create one under Keys & Tokens / API tokens in Coolify)
COOLIFY_API=your_coolify_api_token_here
# Your Coolify instance address (e.g. http://127.0.0.1:8000 or https://app.coolify.io)
COOLIFY_ADDRESS=http://your_coolify_instance_address_here

# OPTIONAL - Coolify Sandbox Agent (Defaults to docker-compose internal network URLs)
# URL to communicate with the sandbox agent HTTP server
COOLIFY_SANDBOX_AGENT_URL=http://sandbox:3001
# Public or exposed URL of the Vite app running in the sandbox
COOLIFY_SANDBOX_VITE_URL=http://localhost:5173

# REQUIRED - Web scraping for cloning websites
# Get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# OPTIONAL - AI Providers (need at least one)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get yours at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
